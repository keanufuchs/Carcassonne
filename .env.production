# Frontend + API (Vercel)
# https://carcasonne.vercel.app

# Multiplayer API — nicht setzen: Production nutzt Same-Origin (/api → Serverless)
# VITE_API_URL=

# WebSocket nur lokal; Production nutzt automatisch HTTP-Polling
# VITE_WS_URL=

# Wird von Vercel automatisch gesetzt, wenn Blob Store angelegt ist:
# BLOB_READ_WRITE_TOKEN=
