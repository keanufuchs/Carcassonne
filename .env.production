# Frontend + API (Vercel)
# https://carcasonne.vercel.app

# Multiplayer API — Same-Origin (Serverless Functions unter /api)
VITE_API_URL=https://carcasonne.vercel.app

# Leer = HTTP-Polling statt WebSocket (Vercel unterstützt keine WS)
VITE_WS_URL=

# Wird von Vercel automatisch gesetzt, wenn Blob Store angelegt ist:
# BLOB_READ_WRITE_TOKEN=
