# Carcassonne — Environment Variables Example
# Copy this file to .env.development and fill in your values.

# WebSocket server URL for network multiplayer (EW-01)
VITE_WS_URL=ws://localhost:3001

# REST API base URL for network multiplayer lobby (create/join games)
VITE_API_URL=http://localhost:3001

# OpenRouter API key for the intelligent AI agent (EW-02)
# Get yours at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-ab...

# AI model to use via OpenRouter (optional, defaults to built-in default)
VITE_AI_MODEL=openai/gpt-oss-120b:free
