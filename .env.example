# ── URLs ────────────────────────────────────────────────────────────────────
#
# Lokal:
#   Frontend   http://localhost:5173        (npm run dev)
#   API + WS   http://localhost:3001        (npm run server / npm run dev:full)
#   MCP AI     http://localhost:3002        (npm run mcp)
#
# Production (Vercel):
#   Frontend + API   https://carcasonne.vercel.app
#
# ── Multiplayer (EW-01) ─────────────────────────────────────────────────────

# REST-API-Basis-URL — nur für lokale Entwicklung (Vite-Proxy /api → :3001)
# Auf Vercel NICHT setzen (Production = Same-Origin /api)
VITE_API_URL=http://localhost:5173

# WebSocket — nur lokal; auf Vercel weglassen (automatisch HTTP-Polling)
VITE_WS_URL=ws://localhost:3001

# ── Server (nur lokal) ──────────────────────────────────────────────────────

PORT=3001
MCP_PORT=3002

# Vercel Blob — wird automatisch gesetzt, wenn Blob Store im Dashboard angelegt ist
# BLOB_READ_WRITE_TOKEN=

# ── Intelligente KI (EW-02) ─────────────────────────────────────────────────

# OpenRouter API key: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-ab...

# Optional, Standard: anthropic/claude-sonnet-4-6
VITE_AI_MODEL=openai/gpt-oss-120b:free
