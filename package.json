{
  "name": "carcassonne",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:lab": "vite --config tile-lab/vite.lab.config.ts",
    "build:lab": "vite build --config tile-lab/vite.lab.config.ts",
    "typecheck:lab": "tsc -p tsconfig.lab.json --noEmit",
    "server": "tsx server/index.ts",
    "mcp": "tsx server/mcp-ai.ts",
    "predev:full": "fuser -k 3001/tcp 3002/tcp 2>/dev/null || true",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\" \"npm run mcp\"",
    "build": "tsc -b && vite build && npm run build:api",
    "build:api": "node scripts/build-api.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build --mode electron",
    "electron:pack": "npm run electron:build && electron-builder",
    "electron:pack:mac": "npm run electron:build && electron-builder --mac",
    "electron:pack:win": "npm run electron:build && electron-builder --win"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vercel/blob": "^2.4.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serverless-http": "^4.0.0",
    "three": "^0.184.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^1.6.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.carcassonne.app",
    "productName": "Carcassonne",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
